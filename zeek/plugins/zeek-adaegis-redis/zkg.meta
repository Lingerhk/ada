[package]
summary = Zeek plugins for ADAegis
description = A Redis queue writer for the Zeek in ADAegis.
tags = adaegis, zeek plugin, redis
credits = adaegislab <https://github.com/adaegislab>
script_dir = scripts
depends =
    zeek >=7.1.0
external_depends =
    hiredis>=1.1.1
    redis-plus-plus>=1.3.12
build_command = (./configure --enable-debug --with-redisplusplus=/usr/local --zeek-dist=%(zeek_dist)s && make)
test_command = make test
